{
  "fetcher": "./target/debug/async_dependency_installer_for_R",
  "include_bioconductor": true,
  "dependency_fields": ["Depends", "Imports", "LinkingTo"],
  "include_suggests": false,
  "download_concurrency": 8,
  "install_ncpus": 1,
  "make_jobs": 1,
  "methods": ["async", "serial"],
  "repetitions": 1,
  "stop_on_error": true,
  "disk_guard": {
    "min_free_gb": 10
  },
  "cleanup": {
    "enabled": true,
    "on_failure": false
  },
  "stacks": {
    "smoke": [
      "jsonlite",
      "digest",
      "cli"
    ]
  }
}
