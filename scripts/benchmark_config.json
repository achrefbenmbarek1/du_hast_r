{
  "fetcher": "./target/debug/async_dependency_installer_for_R",
  "include_bioconductor": true,
  "dependency_fields": ["Depends", "Imports", "LinkingTo"],
  "include_suggests": false,
  "download_concurrency": 16,
  "install_ncpus": 2,
  "make_jobs": 4,
  "methods": ["async", "serial", "tuned", "renv"],
  "repetitions": 3,
  "stop_on_error": false,
  "disk_guard": {
    "min_free_gb": 25
  },
  "cleanup": {
    "enabled": true,
    "on_failure": false
  },
  "stacks": {
    "single_cell_transcriptomics": [
      "SingleCellExperiment",
      "scater",
      "scran",
      "scRNAseq",
      "DropletUtils",
      "Seurat",
      "biomaRt"
    ],
    "neuroimaging_spatial": [
      "RNifti",
      "oro.nifti",
      "neurobase",
      "fslr",
      "ANTsRCore",
      "terra",
      "sf"
    ],
    "bayesian_neuro_modeling": [
      "brms",
      "rstan",
      "rstanarm",
      "bayesplot",
      "posterior",
      "loo",
      "cmdstanr"
    ]
  }
}
