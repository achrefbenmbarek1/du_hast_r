{
  "du_hast_cli": "./target/debug/du_hast_r",
  "fetcher": "./target/debug/async_dependency_installer_for_R",
  "include_bioconductor": true,
  "dependency_fields": ["Depends", "Imports", "LinkingTo"],
  "include_suggests": false,
  "download_concurrency": 16,
  "install_ncpus": 1,
  "make_jobs": 2,
  "methods": ["tuned", "du_hast_dynamic_shared", "du_hast_dynamic_dedicated"],
  "cache_states": ["cold"],
  "repetitions": 1,
  "stop_on_error": false,
  "disk_guard": {
    "min_free_gb": 25
  },
  "cleanup": {
    "enabled": true,
    "on_failure": false
  },
  "stacks": {
    "heavy_realistic": [
      "brms",
      "rstan",
      "rstanarm",
      "StanHeaders",
      "posterior",
      "loo"
    ]
  }
}
